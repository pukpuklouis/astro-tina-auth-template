---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import config from '../content/config/config.json';

type SchemaObject = Record<string, unknown>;

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
	noindex?: boolean;
	schema?: SchemaObject | SchemaObject[];
}

const {
	title,
	description,
	image = config.seo.defaultOgImage || '/blog-placeholder-1.jpg',
	type = 'website',
	noindex = false,
	schema,
} = Astro.props;

const siteURL = Astro.site ?? new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const imageURL = new URL(image, siteURL);
const locale = config.seo.locale || 'en_US';
const twitterHandle = config.seo.twitterHandle?.trim();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';

const sameAsLinks = (config.contactLinks ?? [])
	.map((link) => link?.link)
	.filter((link): link is string => typeof link === 'string' && /^https?:\/\//.test(link));

const baseSchemas: SchemaObject[] = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		name: config.seo.title,
		url: siteURL.toString(),
		inLanguage: locale.replace('_', '-'),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		name: title,
		description,
		url: canonicalURL.toString(),
		isPartOf: {
			'@type': 'WebSite',
			name: config.seo.title,
			url: siteURL.toString(),
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		name: config.seo.siteOwner,
		url: siteURL.toString(),
		sameAs: sameAsLinks,
	},
];

const mergedSchemas = schema
	? [...baseSchemas, ...(Array.isArray(schema) ? schema : [schema])]
	: baseSchemas;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content={config.seo.siteOwner} />
<meta name="robots" content={robots} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:locale" content={locale} />
<meta property="og:site_name" content={config.seo.title} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
{twitterHandle && <meta name="twitter:site" content={twitterHandle} />}

<script type="application/ld+json" set:html={JSON.stringify(mergedSchemas)} />

<ClientRouter />
