---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import config from '../content/config/config.json';

type BlogData = {
	title?: string;
	description?: string;
	heroImage?: string | null;
	pubDate?: string;
	updatedDate?: string;
};

type BlogPostProps = {
	data?: {
		blog?: BlogData;
	};
};

const blog = ((Astro.props as BlogPostProps).data?.blog ?? {}) as BlogData;

const title = blog.title || config.seo.title;
const description = blog.description || config.seo.description;
const image = blog.heroImage || config.seo.defaultOgImage || '/blog-placeholder-1.jpg';

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: blog.pubDate ? new Date(blog.pubDate).toISOString() : undefined,
	dateModified: blog.updatedDate
		? new Date(blog.updatedDate).toISOString()
		: blog.pubDate
			? new Date(blog.pubDate).toISOString()
			: undefined,
	author: {
		'@type': 'Person',
		name: config.seo.siteOwner,
	},
	publisher: {
		'@type': 'Organization',
		name: config.seo.siteOwner,
	},
	image,
	mainEntityOfPage: Astro.url.toString(),
};
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={image}
			type="article"
			schema={articleSchema}
		/>
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
