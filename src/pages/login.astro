---
// Simple login page for magic link authentication
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>登入 - TinaCMS Admin</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    
    .login-container {
      background: white;
      border-radius: 16px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
      padding: 48px;
      width: 100%;
      max-width: 400px;
    }
    
    .logo {
      text-align: center;
      margin-bottom: 32px;
    }
    
    .logo h1 {
      font-size: 28px;
      color: #1a202c;
      font-weight: 700;
    }
    
    .logo p {
      color: #718096;
      margin-top: 8px;
      font-size: 14px;
    }
    
    .form-group {
      margin-bottom: 24px;
    }
    
    label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      color: #2d3748;
      margin-bottom: 8px;
    }
    
    input[type="email"] {
      width: 100%;
      padding: 12px 16px;
      border: 2px solid #e2e8f0;
      border-radius: 8px;
      font-size: 16px;
      transition: border-color 0.2s;
    }
    
    input[type="email"]:focus {
      outline: none;
      border-color: #667eea;
    }
    
    button {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    
    button:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
    }
    
    button:active {
      transform: translateY(0);
    }
    
    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    
    .message {
      margin-top: 24px;
      padding: 16px;
      border-radius: 8px;
      text-align: center;
      font-size: 14px;
    }
    
    .message.success {
      background: #c6f6d5;
      color: #22543d;
    }
    
    .message.error {
      background: #fed7d7;
      color: #742a2a;
    }
    
    .message.hidden {
      display: none;
    }
    
    .back-link {
      text-align: center;
      margin-top: 24px;
    }
    
    .back-link a {
      color: #667eea;
      text-decoration: none;
      font-size: 14px;
    }
    
    .back-link a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <div class="logo">
      <h1>TinaCMS Admin</h1>
      <p>輸入您的電子郵件以接收登入連結</p>
    </div>
    
    <form id="loginForm">
      <div class="form-group">
        <label for="email">電子郵件</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          placeholder="your@email.com"
          autocomplete="email"
        />
      </div>
      
      <button type="submit" id="submitBtn">
        發送登入連結
      </button>
    </form>
    
    <div id="message" class="message hidden"></div>
    
    <div class="back-link">
      <a href="/">← 返回首頁</a>
    </div>
  </div>
  
  <script>
    const form = document.getElementById('loginForm');
    const emailInput = document.getElementById('email');
    const submitBtn = document.getElementById('submitBtn');
    const messageDiv = document.getElementById('message');
    
    // Get callback URL from query params
    const urlParams = new URLSearchParams(window.location.search);
    const callbackUrl = urlParams.get('callbackUrl') || '/admin';
    
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = emailInput.value.trim();
      if (!email) {
        showMessage('請輸入電子郵件地址', 'error');
        return;
      }
      
      // Disable form while submitting
      submitBtn.disabled = true;
      submitBtn.textContent = '發送中...';
      
      try {
        const response = await fetch('/api/auth/sign-in/magic-link', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            email: email,
            callbackURL: callbackUrl,
          }),
        });
        
        if (response.ok) {
          showMessage(
            '登入連結已發送到您的電子郵件！請檢查收件匣（和垃圾郵件資料夾）。',
            'success'
          );
          form.reset();
        } else {
          const error = await response.text();
          showMessage(
            '發送失敗。請確認電子郵件地址正確，或稍後再試。',
            'error'
          );
        }
      } catch (error) {
        console.error('Login error:', error);
        showMessage('網路錯誤。請檢查網路連線後重試。', 'error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = '發送登入連結';
      }
    });
    
    function showMessage(text, type) {
      messageDiv.textContent = text;
      messageDiv.className = `message ${type}`;
      
      // Auto-hide success messages after 10 seconds
      if (type === 'success') {
        setTimeout(() => {
          messageDiv.className = 'message hidden';
        }, 10000);
      }
    }
  </script>
</body>
</html>
